generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Owner {
  id        String     @id @default(cuid())
  userId    String
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  properties         Property[]
  trustTransactions  TrustTransaction[]

  @@index([userId])
}

model Tenant {
  id                String    @id @default(cuid())
  userId            String
  firstName         String
  lastName          String
  email             String?
  phone             String?
  address           String?
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  leases            Lease[]
  payments          Payment[]
  trustTransactions TrustTransaction[]

  @@index([userId])
}

model Property {
  id         String   @id @default(cuid())
  userId     String
  name       String
  address    String
  city       String
  state      String
  zip        String
  type       String   @default("apartment")
  bedrooms   Int?
  bathrooms  Float?
  sqft       Int?
  rentAmount Float
  feeType    String?
  feeAmount  Float?
  ownerId    String
  owner      Owner    @relation(fields: [ownerId], references: [id])
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  leases     Lease[]

  @@index([userId])
}

model Lease {
  id              String     @id @default(cuid())
  userId          String
  propertyId      String
  property        Property   @relation(fields: [propertyId], references: [id])
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  startDate       DateTime
  endDate         DateTime?
  rentAmount      Float
  securityDeposit Float?
  status          String     @default("active")
  ledgerStartDate DateTime?
  openingBalance  Float      @default(0)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  payments        Payment[]
  contracts       Contract[]
  trustTransactions TrustTransaction[]

  @@index([userId])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  leaseId         String
  lease           Lease    @relation(fields: [leaseId], references: [id])
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  amount          Float
  datePaid        DateTime
  periodStart     DateTime
  periodEnd       DateTime
  method          String
  referenceNumber String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  trustTransactions TrustTransaction[]

  @@index([userId])
}

model Contract {
  id          String   @id @default(cuid())
  userId      String
  leaseId     String
  lease       Lease    @relation(fields: [leaseId], references: [id])
  fileName    String
  filePath    String
  fileSize    Int
  description String?
  uploadedAt  DateTime @default(now())

  @@index([userId])
}

model TrustTransaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Float
  balance     Float
  date        DateTime
  description String?
  notes       String?
  paymentId   String?
  payment     Payment? @relation(fields: [paymentId], references: [id])
  leaseId     String?
  lease       Lease?   @relation(fields: [leaseId], references: [id])
  ownerId     String?
  owner       Owner?   @relation(fields: [ownerId], references: [id])
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId])
}
